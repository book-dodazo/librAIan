# ================================================================
# 이 파일을 복사해서 backend-secret.yaml 을 만들고 실제 값을 채우세요.
# backend-secret.yaml 은 .gitignore 에 등록되어 git에 올라가지 않습니다.
#
# 적용: kubectl apply -f k8s/backend-secret.yaml
# ================================================================
apiVersion: v1
kind: Secret
metadata:
  name: backend-secret
  namespace: libraian
type: Opaque
stringData:
  CLOVA_API_KEY:      "여기에-실제-키-입력"
  NARU_API_KEY:       "여기에-실제-키-입력"
  ELASTIC_URL:        "http://elasticsearch:9200"
  ELASTIC_USER:       "elastic"
  ELASTIC_PASSWORD:   "여기에-실제-비밀번호-입력"
